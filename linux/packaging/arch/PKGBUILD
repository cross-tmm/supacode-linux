# Maintainer: Supacode Maintainers <maintainers@example.invalid>
pkgname=supacode
pkgver=0.1.0
pkgrel=1
pkgdesc='Terminal-native command center for coding agents'
arch=('x86_64' 'aarch64')
url='https://github.com/cross-tmm/supacode-linux'
license=('custom:FSL-1.1-ALv2')
depends=('git' 'github-cli' 'nodejs' 'openssh' 'qt6-base' 'qt6-svg' 'sqlite')
makedepends=('cmake' 'gcc' 'pkgconf')
source=("$pkgname::git+https://github.com/cross-tmm/supacode-linux.git")
sha256sums=('SKIP')

build() {
  cd "$srcdir/$pkgname"
  cmake -S linux/qt -B build/linux/qt -DCMAKE_BUILD_TYPE=RelWithDebInfo
  cmake --build build/linux/qt
}

check() {
  cd "$srcdir/$pkgname"
  node --test linux/test/*.test.mjs
}

package() {
  cd "$srcdir/$pkgname"
  install -Dm755 "build/linux/qt/supacode" "$pkgdir/usr/bin/supacode"
  install -Dm755 "linux/packaging/bin/supacode-linux" "$pkgdir/usr/bin/supacode-linux"
  install -Dm644 "linux/src/supacode-linux.mjs" "$pkgdir/usr/lib/supacode-linux/supacode-linux.mjs"
  install -Dm644 "linux/src/utils.mjs" "$pkgdir/usr/lib/supacode-linux/utils.mjs"
  install -Dm644 "linux/src/remote-git.mjs" "$pkgdir/usr/lib/supacode-linux/remote-git.mjs"
  install -Dm644 "linux/src/terminal-launch.mjs" "$pkgdir/usr/lib/supacode-linux/terminal-launch.mjs"
  install -Dm644 "linux/src/agent-integrations.mjs" "$pkgdir/usr/lib/supacode-linux/agent-integrations.mjs"
  install -Dm644 "linux/src/github-status.mjs" "$pkgdir/usr/lib/supacode-linux/github-status.mjs"
  install -Dm644 "linux/state/migrations/0001_initial.sql" \
    "$pkgdir/usr/share/supacode-linux/state/migrations/0001_initial.sql"
  install -Dm644 "linux/state/migrations/0002_agent_events.sql" \
    "$pkgdir/usr/share/supacode-linux/state/migrations/0002_agent_events.sql"
  install -Dm644 "linux/state/migrations/0003_terminal_launch_state.sql" \
    "$pkgdir/usr/share/supacode-linux/state/migrations/0003_terminal_launch_state.sql"
  install -Dm644 "linux/state/migrations/0004_github_pull_requests.sql" \
    "$pkgdir/usr/share/supacode-linux/state/migrations/0004_github_pull_requests.sql"
  install -Dm644 "linux/state/migrations/0005_terminal_launch_plan.sql" \
    "$pkgdir/usr/share/supacode-linux/state/migrations/0005_terminal_launch_plan.sql"
  install -Dm644 "linux/packaging/appimage/supacode.desktop" \
    "$pkgdir/usr/share/applications/supacode.desktop"
  install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
