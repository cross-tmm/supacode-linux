#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  clean)
    rm -rf debian/supacode-linux
    ;;
  build)
    node --test linux/test/*.test.mjs
    ;;
  binary)
    mkdir -p debian/supacode-linux/usr/bin debian/supacode-linux/usr/lib/supacode-linux
    cp linux/packaging/bin/supacode-linux debian/supacode-linux/usr/bin/supacode-linux
    cp linux/src/supacode-linux.mjs linux/src/utils.mjs debian/supacode-linux/usr/lib/supacode-linux/
    chmod 755 debian/supacode-linux/usr/bin/supacode-linux
    ;;
  *)
    echo "usage: debian/rules clean|build|binary" >&2
    exit 64
    ;;
esac
