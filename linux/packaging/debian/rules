#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  clean)
    rm -rf debian/agent-workbench
    ;;
  build)
    node --test linux/test/*.test.mjs
    ;;
  binary)
    mkdir -p debian/agent-workbench/usr/bin debian/agent-workbench/usr/lib/supacode-linux debian/agent-workbench/usr/lib/agent-workbench/app debian/agent-workbench/usr/share/supacode-linux/state
    cp linux/packaging/bin/supacode-linux debian/agent-workbench/usr/bin/supacode-linux
    cp linux/packaging/bin/agent-workbench debian/agent-workbench/usr/bin/agent-workbench
    cp linux/src/supacode-linux.mjs linux/src/utils.mjs linux/src/remote-git.mjs linux/src/terminal-launch.mjs linux/src/agent-integrations.mjs linux/src/github-status.mjs debian/agent-workbench/usr/lib/supacode-linux/
    cp linux/src/app/agent-workbench.gjs debian/agent-workbench/usr/lib/agent-workbench/app/
    cp -R linux/state/migrations debian/agent-workbench/usr/share/supacode-linux/state/
    chmod 755 debian/agent-workbench/usr/bin/supacode-linux debian/agent-workbench/usr/bin/agent-workbench
    ;;
  *)
    echo "usage: debian/rules clean|build|binary" >&2
    exit 64
    ;;
esac
