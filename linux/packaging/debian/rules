#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  clean)
    rm -rf debian/supacode build/linux/qt
    ;;
  build)
    bash linux/scripts/build-qt.sh
    node --test linux/test/*.test.mjs
    ;;
  binary)
    bash linux/scripts/build-qt.sh
    mkdir -p debian/supacode/usr/bin debian/supacode/usr/lib/supacode-linux debian/supacode/usr/share/supacode-linux/state debian/supacode/usr/share/applications
    cp build/linux/qt/supacode debian/supacode/usr/bin/supacode
    cp linux/packaging/bin/supacode-linux debian/supacode/usr/bin/supacode-linux
    cp linux/src/supacode-linux.mjs linux/src/utils.mjs linux/src/remote-git.mjs linux/src/terminal-launch.mjs linux/src/agent-integrations.mjs linux/src/github-status.mjs debian/supacode/usr/lib/supacode-linux/
    cp -R linux/state/migrations debian/supacode/usr/share/supacode-linux/state/
    cp linux/packaging/appimage/supacode.desktop debian/supacode/usr/share/applications/supacode.desktop
    chmod 755 debian/supacode/usr/bin/supacode debian/supacode/usr/bin/supacode-linux
    ;;
  *)
    echo "usage: debian/rules clean|build|binary" >&2
    exit 64
    ;;
esac
